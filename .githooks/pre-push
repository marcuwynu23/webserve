#!/bin/sh
# OFF by default so `git push` never waits on this hook (fixes long “stack” before upload).
# Before pushing a version tag, run either:
#   WEBSERVE_HOOK_VERSION_CHECK=1 git push origin v1.2.1
# or rely on CI (publish workflow already checks tag vs Cargo.toml).
#
# Enable hooks dir: git config core.hooksPath .githooks

[ "${WEBSERVE_HOOK_VERSION_CHECK:-0}" = 1 ] || exit 0

INPUT=$(cat) || true
echo "$INPUT" | grep -q 'refs/tags/v' || exit 0

REPO_ROOT=$(git rev-parse --show-toplevel) || exit 1
cd "$REPO_ROOT" || exit 1

toml=$(sed -n 's/^version = "\([^"]*\)"/\1/p' Cargo.toml | head -n1)
lock=$(awk '/^\[\[package\]\]/{p=0} $0=="name = \"webserve\""{p=1;next} p&&/^version = "/{gsub(/version = "|"/,"");print;exit}' Cargo.lock)
FAILED=0
for r in $(echo "$INPUT" | awk '{print $3}'); do
  case "$r" in
    refs/tags/v*)
      tv=${r#refs/tags/v}
      [ -z "$toml" ] && echo "pre-push: no Cargo.toml version" >&2 && FAILED=1 && continue
      [ -z "$lock" ] && echo "pre-push: no webserve in Cargo.lock" >&2 && FAILED=1 && continue
      [ "$tv" != "$toml" ] && echo "pre-push: tag v$tv != toml $toml" >&2 && FAILED=1
      [ "$toml" != "$lock" ] && echo "pre-push: toml $toml != lock $lock" >&2 && FAILED=1
      ;;
  esac
done
[ "$FAILED" != 0 ] && exit 1
echo "pre-push: tag / Cargo.toml / Cargo.lock OK"
case "${WEBSERVE_HOOK_RUN_CARGO:-0}" in 1|true|yes) cargo check -q || exit 1 ;; esac
exit 0
